---
import "../styles/global.css";
import { profile } from "../data/site";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Yunxi Kong",
  description = "Academic website of Yunxi Kong, featuring research interests, projects, publications, and CV."
} = Astro.props;

const pageTitle = title === "Yunxi Kong" ? title : `${title} | Yunxi Kong`;
const siteUrl = "https://yunxi-kong.github.io";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(profile.portrait, siteUrl).toString();
const navItems = [
  { href: "/", label: "Home" },
  { href: "/research/", label: "Research" },
  { href: "/projects/", label: "Projects" },
  { href: "/publications/", label: "Publications" },
  { href: "/cv/", label: "CV" },
  { href: "/about/", label: "About" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f7f9" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Yunxi Kong home">
          <span class="brand-mark">YK</span>
          <span>Yunxi Kong</span>
        </a>
        <div class="nav-links">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <strong>Yunxi Kong</strong>
        <p>Duke University / Economics and Computation / AI, learning, and human-centered systems</p>
        <p class="footer-email">{profile.email}</p>
      </div>
      <div class="footer-links">
        <a href={profile.github}>GitHub</a>
        <a href={profile.linkedin}>LinkedIn</a>
        <a href={profile.edtech}>EdTech work</a>
      </div>
    </footer>
  </body>
</html>
