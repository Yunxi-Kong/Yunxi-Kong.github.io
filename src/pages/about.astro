---
import BaseLayout from "../layouts/BaseLayout.astro";
import { education, profile } from "../data/site";
---

<BaseLayout
  title="About"
  description="About Yunxi Kong."
>
  <section class="about-hero">
    <img src={profile.portrait} alt="Portrait of Yunxi Kong" />
    <div>
      <p class="page-label">About</p>
      <h1>About Yunxi Kong</h1>
      <p>
        I came to Duke's M.S. in Economics and Computation with training in
        economics and mathematics and a broad goal: to become a researcher who can
        move across quantitative social science, computation, and learning. During
        the program, I have used coursework and research projects to build a more
        concrete direction around AI-supported learning systems, learning analytics,
        and human-centered educational technology.
      </p>
      <p>
        My current work combines system building and empirical analysis. I have
        built AI-assisted history reading and annotation systems, studied adaptive
        recommendation effects in tutoring data, and contributed to a learning
        analytics paper accepted at LAK 2026. Outside this academic website, I also
        maintain broader education technology work through Ingenius Prime.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">View Projects</a>
        <a class="button secondary" href={profile.edtech} target="_blank" rel="noreferrer">Ingenius Prime</a>
      </div>
    </div>
  </section>

  <section class="content-section">
    <h2>Research profile</h2>
    <div class="profile-columns">
      <article>
        <h3>What I study</h3>
        <p>
          I am interested in how AI systems can support learning without hiding
          the learner's reasoning process. This includes annotation, discussion,
          feedback, multimodal explanation, and teacher-facing inspection views.
        </p>
      </article>
      <article>
        <h3>How I work</h3>
        <p>
          I tend to pair working prototypes with empirical methods: causal inference,
          learning analytics, corpus classification, and human-in-the-loop validation.
        </p>
      </article>
      <article>
        <h3>Where I am going</h3>
        <p>
          I am preparing for PhD-level research on AI, learning, and human-machine
          systems, while keeping a connection to educational equity and real learning
          settings.
        </p>
      </article>
    </div>
  </section>

  <section class="content-section">
    <h2>Education and training</h2>
    <div class="timeline-list">
      {education.map((item) => (
        <article>
          <time>{item.period}</time>
          <h3>{item.institution}</h3>
          <p>{item.degree} / {item.place}</p>
          <p>{item.note}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
