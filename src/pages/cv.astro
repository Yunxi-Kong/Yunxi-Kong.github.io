---
import BaseLayout from "../layouts/BaseLayout.astro";
import { education, methodGroups, profile, profileHighlights } from "../data/site";
import { projects } from "../data/projects";
import { publications } from "../data/publications";
---

<BaseLayout
  title="CV"
  description="Curriculum vitae and academic background of Yunxi Kong."
>
  <section class="page-hero compact-hero cv-hero">
    <div>
      <p class="page-label">CV</p>
      <h1>Curriculum Vitae</h1>
      <p>
        This page provides a web summary of my current CV. A PDF version is available
        for applications and reference.
      </p>
    </div>
    <a class="button primary" href={profile.cv}>Download PDF</a>
  </section>

  <section class="cv-layout">
    <aside class="cv-sidebar">
      <h2>Contact</h2>
      <p class="email-text">{profile.email}</p>
      <p><a href={profile.github} target="_blank" rel="noreferrer">GitHub</a></p>
      <p><a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a></p>
    </aside>
    <div class="cv-main">
      <section>
        <h2>Academic Highlights</h2>
        <div class="profile-highlight-grid cv-highlight-grid">
          {profileHighlights.map((item) => (
            <article>
              <strong>{item.value}</strong>
              <span>{item.label}</span>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>
      <section>
        <h2>Education</h2>
        <div class="timeline-list">
          {education.map((item) => (
            <article>
              <time>{item.period}</time>
              <h3>{item.institution}</h3>
              <p>{item.degree}</p>
              <p>{item.note}</p>
            </article>
          ))}
        </div>
      </section>
      <section>
        <h2>Selected Research Experience</h2>
        <div class="cv-project-list">
          {projects.slice(0, 6).map((project) => (
            <article>
              <h3>{project.title}</h3>
              <p>{project.summary}</p>
            </article>
          ))}
        </div>
      </section>
      <section>
        <h2>Publications and Manuscripts</h2>
        <div class="cv-project-list">
          {publications.slice(0, 3).map((publication) => (
            <article>
              <h3>{publication.title}</h3>
              <p>{publication.authors}. {publication.status}</p>
            </article>
          ))}
        </div>
      </section>
      <section>
        <h2>Technical Skills</h2>
        <div class="method-grid compact-method-grid">
          {methodGroups.map((group) => (
            <article>
              <h3>{group.title}</h3>
              <div class="tag-row">
                {group.items.map((item) => <span>{item}</span>)}
              </div>
            </article>
          ))}
        </div>
        <p>Core tools: Python, R, React/TypeScript, JavaScript, Stata, MATLAB, LaTeX, and Git.</p>
      </section>
    </div>
  </section>
</BaseLayout>
