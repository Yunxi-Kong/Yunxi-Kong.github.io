---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PublicationItem from "../components/PublicationItem.astro";
import { featuredProjects } from "../data/projects";
import { publications } from "../data/publications";
import { education, news, profile, researchInterests } from "../data/site";

const selectedPublications = publications.slice(0, 3);
---

<BaseLayout
  title="Yunxi Kong"
  description="Academic website of Yunxi Kong, a Duke M.S. student in Economics and Computation working across AI, learning systems, HCI, learning analytics, and computational social science."
>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="page-label">Academic Website</p>
      <h1>Yunxi Kong</h1>
      <p class="hero-role">M.S. in Economics and Computation, Duke University</p>
      <p class="hero-text">
        I am developing an interdisciplinary research path across AI, learning systems,
        human-centered computing, learning analytics, and computational social science.
        My recent work includes AI-supported history learning environments, causal
        evaluation of tutoring systems, and large-scale analysis of learning analytics
        research.
      </p>
      <div class="interest-list" aria-label="Research interests">
        {researchInterests.map((interest) => <span>{interest}</span>)}
      </div>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">View Projects</a>
        <a class="button secondary" href={profile.cv}>Download CV</a>
        <a class="button text" href="#contact">Contact</a>
      </div>
    </div>
    <aside class="portrait-panel" aria-label="Portrait and contact summary">
      <img src={profile.portrait} alt="Portrait of Yunxi Kong" />
      <div class="portrait-card">
        <p>Duke University · Durham, NC</p>
        <p class="email-text">{profile.email}</p>
        <div class="portrait-links">
          <a href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
          <a href={profile.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </aside>
  </section>

  <section class="home-overview" aria-label="Education and news">
    <div class="education-panel">
      <SectionHeader
        kicker="Education"
        title="Education and training"
        text="A concise academic timeline for visitors who want to understand my background quickly."
      />
      <div class="education-list">
        {education.map((item) => (
          <article class="education-item">
            <div class="school-logo">
              <img src={item.logo} alt={item.logoAlt} />
            </div>
            <div>
              <div class="education-heading">
                <h3>{item.institution}</h3>
                <time>{item.period}</time>
              </div>
              <p class="degree">{item.degree}</p>
              <p>{item.place}</p>
              <p>{item.note}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
    <aside class="news-panel early-news">
      <h2>News</h2>
      <div class="news-list">
        {news.map((item) => (
          <article>
            <time>{item.date}</time>
            <p>{item.text}</p>
            <span>{item.detail}</span>
          </article>
        ))}
      </div>
    </aside>
  </section>

  <section class="content-section">
    <SectionHeader
      kicker="Selected Work"
      title="Selected projects"
      text="The project pages collect system-building work, empirical analysis, and course research from my master's training."
    />
    <div class="selected-work-list">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="section-link">
      <a href="/projects/">Browse all projects</a>
    </div>
  </section>

  <section class="content-section">
    <SectionHeader
      kicker="Publications"
      title="Publications, manuscripts, and selected research"
      text="This section separates accepted work from manuscripts and selected course research so the record stays clear."
    />
    <div class="publication-list short-list">
      {selectedPublications.map((publication) => <PublicationItem publication={publication} />)}
    </div>
    <div class="section-link">
      <a href="/publications/">View publication list</a>
    </div>
  </section>

  <section class="content-section bridge-section" id="contact">
    <div>
      <p class="eyebrow">More Context</p>
      <h2>Additional academic and education technology materials</h2>
      <p>
        This website keeps the front page focused on academic materials. For my broader
        education technology work in China, visit Ingenius Prime. For project details,
        papers, code, and CV materials, use the navigation links above.
      </p>
      <p class="contact-line">Email: <span>{profile.email}</span></p>
    </div>
    <div class="bridge-actions">
      <a class="button primary" href={profile.edtech} target="_blank" rel="noreferrer">Visit Ingenius Prime</a>
      <a class="button secondary" href="/research/">Research interests</a>
    </div>
  </section>
</BaseLayout>
